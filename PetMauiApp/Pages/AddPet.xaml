<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PetMauiApp.Pages.AddPet"
             Shell.NavBarIsVisible="False"
             Title="AddPet">
    <Grid RowDefinitions="60, *">

        <Grid BackgroundColor="{StaticResource PassColor}" Padding="15,0">
            <Label Text="←" TextColor="{StaticResource BtnTextColor}" FontSize="25" VerticalOptions="Center"/>
            <Label Text="Add Pets" TextColor="{StaticResource BtnTextColor}" FontSize="18" 
                   HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold"/>
        </Grid>

        <ScrollView Grid.Row="1" BackgroundColor="{StaticResource BtnTextColor}">
            <VerticalStackLayout Padding="0,0,0,20">

                <VerticalStackLayout Padding="20">
                    <Button Text="Scan for Pets" BackgroundColor="{StaticResource PassColor}" TextColor="{StaticResource TextColor}"
                            CornerRadius="20" HorizontalOptions="End" WidthRequest="150" HeightRequest="45"/>
                    <Label Text="Added Pets" FontSize="20" FontAttributes="Bold" Margin="0,20,0,10" TextColor="{StaticResource TextColor}"/>
                </VerticalStackLayout>

                <CollectionView ItemsSource="{Binding PetModels}" 
                                SelectionMode="Single"
                                Margin="0,0,0,20">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="15"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeThickness="0" Padding="15,10" BackgroundColor="#D9D9D9" Margin="25,0,25,0" HeightRequest="90">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="15" />
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="60, *, Auto">
                                    <Image Source="{Binding Image}" HeightRequest="40" WidthRequest="40" Aspect="AspectFit" BackgroundColor="{Binding Color}"/>
                                    <Label Grid.Column="1" Text="{Binding Name}" FontAttributes="Bold" 
                                           VerticalOptions="Center" Margin="15,0" FontSize="16" TextColor="{StaticResource TextColor}"/>
                                    <Label Grid.Column="2" Text="🔗" FontSize="20" VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <VerticalStackLayout Padding="20" Spacing="15">
                    <Label Text="Manually Add Pet" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource TextColor}" Margin="0,0,0,5"/>

                    <Border StrokeShape="RoundRectangle 15" StrokeThickness="0" BackgroundColor="{StaticResource groundcolor}" HeightRequest="55" Padding="15,0">
                        <Entry Placeholder="Pet Name" PlaceholderColor="{StaticResource TitleColor}" VerticalOptions="Center" TextColor="{StaticResource TextColor}"/>
                    </Border>

                    <Border StrokeShape="RoundRectangle 15" StrokeThickness="2" BackgroundColor="{StaticResource groundcolor}" HeightRequest="55" Padding="15,0">
                        <Entry Placeholder="Breed Name" PlaceholderColor="{StaticResource TitleColor}" VerticalOptions="Center" TextColor="{StaticResource TextColor}"/>
                    </Border>

                    <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10">
                        <Border Grid.Column="0" StrokeShape="RoundRectangle 15" StrokeThickness="0" BackgroundColor="{StaticResource groundcolor}" HeightRequest="50" Padding="10,0">
                            <Entry Placeholder="Gender" PlaceholderColor="{StaticResource TitleColor}" VerticalOptions="Center" FontSize="14" HorizontalTextAlignment="Center" TextColor="{StaticResource TextColor}"/>
                        </Border>
                        <Border Grid.Column="1" StrokeShape="RoundRectangle 15" StrokeThickness="0" BackgroundColor="{StaticResource groundcolor}" HeightRequest="50" Padding="10,0">
                            <Entry Placeholder="Age" PlaceholderColor="{StaticResource TitleColor}" VerticalOptions="Center" FontSize="14" HorizontalTextAlignment="Center" Keyboard="Numeric" TextColor="{StaticResource TextColor}"/>
                        </Border>
                        <Border Grid.Column="2" StrokeShape="RoundRectangle 15" StrokeThickness="0" BackgroundColor="{StaticResource groundcolor}" HeightRequest="50" Padding="10,0">
                            <Entry Placeholder="Colour" PlaceholderColor="{StaticResource TitleColor}" VerticalOptions="Center" FontSize="14" HorizontalTextAlignment="Center" TextColor="{StaticResource TextColor}"/>
                        </Border>
                    </Grid>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                        <Border Grid.Column="0" StrokeShape="RoundRectangle 15" StrokeThickness="0" BackgroundColor="{StaticResource groundcolor}" HeightRequest="50" Padding="10,0">
                            <Entry Placeholder="Height" PlaceholderColor="{StaticResource TitleColor}" VerticalOptions="Center" FontSize="14" HorizontalTextAlignment="Center" TextColor="{StaticResource TextColor}"/>
                        </Border>
                        <Border Grid.Column="1" StrokeShape="RoundRectangle 15" StrokeThickness="0" BackgroundColor="{StaticResource groundcolor}" HeightRequest="50" Padding="10,0">
                            <Entry Placeholder="Weight" PlaceholderColor="{StaticResource TitleColor}" VerticalOptions="Center" FontSize="14" HorizontalTextAlignment="Center" TextColor="{StaticResource TextColor}"/>
                        </Border>
                    </Grid>

                    <Button Text="Add Pet" 
                            BackgroundColor="{StaticResource PassColor}" 
                            TextColor="White" 
                            FontAttributes="Bold"
                            CornerRadius="10" 
                            HeightRequest="55" 
                            Margin="0,10,0,10"
                            Clicked="Btn_Dash"/>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>