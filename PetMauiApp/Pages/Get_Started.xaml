<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PetMauiApp.Pages.Get_Started"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{StaticResource BgColor}"
             Title="Get_Started">
    <Grid >

        <VerticalStackLayout
             Spacing="20"
             VerticalOptions="Center"
             HorizontalOptions="Center">

            <Image
                 Source="pet"
                 HeightRequest="300"
                 WidthRequest="250"
                 HorizontalOptions="Center"/>

            <Label
                 Text="Hey! Welcome"
                FontAttributes="Bold"
                 FontFamily="PoppinsBolditalic"
                 FontSize="26"
                 HorizontalOptions="Center"
                 TextColor="{StaticResource TextColor}"/>

            <Label
                 Text="While You Sit And Stay - We'll Go Out And Play"
                 HorizontalTextAlignment="Center"
                FontAttributes="Bold"
                 LineBreakMode="WordWrap"
                 MaximumWidthRequest="250"
                 FontFamily="PoppinsRegular"
                 FontSize="16"
                 TextColor="{StaticResource TitleColor}"/>

            <Button
                 Text="GET STARTED >"
                 BackgroundColor="{StaticResource BtnColor}"
                 TextColor="{StaticResource BtnTextColor}"
                 CornerRadius="30"
                FontAttributes="Bold"
                 Padding="25,12"
                 Clicked="get_started"
                 FontFamily="PoppinsBold"
                 HorizontalOptions="Center"/>

            <HorizontalStackLayout
                 HorizontalOptions="Center"
                 Spacing="5">

                <Label
                     Text="Already have an account?"
                     FontSize="16"
                    FontAttributes="Bold"
                     TextColor="{StaticResource TextColor}"
                     FontFamily="PoppinsBolditalic"/>

                <Label
                  Text="Login"
                  FontSize="16"
                    FontAttributes="Bold"
                  FontFamily="PoppinsBold"
                  TextColor="{StaticResource BtnColor}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="login"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </Grid>
</ContentPage>