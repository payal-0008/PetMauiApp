<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PetMauiApp.Pages.VetPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource BtnTextColor}"
             Title="VetPage">
    
    <Grid RowDefinitions="*, 70">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="20" Padding="0,0,0,20">

                <BoxView HeightRequest="70" Color="{StaticResource PassColor}" />

                <VerticalStackLayout Padding="20,0" Spacing="20" Margin="0,-60,0,0">
                    <Label Text="Hello, How may I help you?"
                           FontSize="22" FontAttributes="Bold" />

                    <HorizontalStackLayout Spacing="30" HorizontalOptions="Center" Margin="0,10,0,0">

                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Frame x:Name="VetFrame"
                                   BackgroundColor="{StaticResource PassColor}"
                                   CornerRadius="15" Padding="15" HasShadow="False">
                                <Image Source="vet_paw.png" WidthRequest="30" HeightRequest="30" />
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="Veterinary" />
                                </Frame.GestureRecognizers>
                            </Frame>
                            <Label Text="Veterinary" HorizontalTextAlignment="Center"
                                   FontSize="12" TextColor="{StaticResource TitleColor}"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Frame x:Name="GroomFrame"
                                   BackgroundColor="{StaticResource EntryColor}"
                                   CornerRadius="15" Padding="15" HasShadow="False">
                                <Image Source="grooming_icon.png" WidthRequest="30" HeightRequest="30" />
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="Grooming" />
                                </Frame.GestureRecognizers>
                            </Frame>
                            <Label Text="Grooming" HorizontalTextAlignment="Center"
                                   FontSize="12" TextColor="{StaticResource TitleColor}"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Frame x:Name="BoardFrame"
                                   BackgroundColor="{StaticResource EntryColor}"
                                   CornerRadius="15" Padding="15" HasShadow="False">
                                <Image Source="boarding_icon.png" WidthRequest="30" HeightRequest="30" />
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnCategoryTapped" CommandParameter="Boarding" />
                                </Frame.GestureRecognizers>
                            </Frame>
                            <Label Text="Boarding" HorizontalTextAlignment="Center"
                                   FontSize="12" TextColor="{StaticResource TitleColor}"/>
                        </VerticalStackLayout>

                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <BoxView HeightRequest="1" Color="{StaticResource TitleColor}" Margin="20,0" />

                <VerticalStackLayout Padding="20,0" Spacing="10">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label x:Name="NearbyTitle"
                               Text="Nearby Veterinarian"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="{StaticResource TextColor}" />
                        <Label Grid.Column="1" Text="See all"
                               TextColor="{StaticResource TitleColor}"
                               VerticalOptions="Center" />
                    </Grid>

                    <CollectionView x:Name="NearbyList">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeShape="RoundRectangle 15"
                                        StrokeThickness="1"
                                        Stroke="{StaticResource EntryColor}"
                                        Padding="15" Margin="0,0,0,0">
                                    <Grid ColumnDefinitions="Auto, *"
                                          RowDefinitions="Auto, Auto, Auto"
                                          ColumnSpacing="15">

                                        <Image Grid.RowSpan="3"
                                               Source="{Binding ImageUrl}"
                                               WidthRequest="60" HeightRequest="60"
                                               Aspect="AspectFill">
                                            <Image.Clip>
                                                <RoundRectangleGeometry CornerRadius="10" Rect="0,0,60,60"/>
                                            </Image.Clip>
                                        </Image>

                                        <VerticalStackLayout Grid.Column="1">
                                            <Label Text="{Binding Name}"
                                                   FontAttributes="Bold" FontSize="16"
                                                   TextColor="{StaticResource TextColor}" />
                                            <Label Text="{Binding Specialization}"
                                                   FontSize="12" TextColor="Gray" />
                                            <HorizontalStackLayout Spacing="5">
                                                <Label Text="⭐⭐⭐⭐⭐" FontSize="10" VerticalOptions="Center"/>
                                                <Label Text="{Binding Rating}"
                                                       FontSize="11" FontAttributes="Bold"
                                                       TextColor="{StaticResource TextColor}"/>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>

                                        <HorizontalStackLayout Grid.Row="1" Grid.Column="1"
                                                               Spacing="15" Margin="0,5">

                                            <Border StrokeShape="RoundRectangle 5"
                                                    BackgroundColor="#E8F5E9"
                                                    Padding="6,2">
                                                <Label Text="{Binding Status}"
                                                       FontSize="10" FontAttributes="Bold"
                                                       TextColor="#4CAF50"/>
                                            </Border>
                                            <Label Text="{Binding Experience}"
                                                   FontSize="11"
                                                   TextColor="{StaticResource TitleColor}" />
                                            <Label Text="{Binding Distance}"
                                                   FontSize="11"
                                                   TextColor="{StaticResource TitleColor}" />
                                        </HorizontalStackLayout>

                                        <Label Grid.Row="2" Grid.Column="1"
                                               Text="{Binding Schedule}"
                                               FontSize="11"
                                               TextColor="{StaticResource TitleColor}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <BoxView HeightRequest="1" Color="{StaticResource TitleColor}" Margin="20,0" />

                <VerticalStackLayout Padding="20,0" Spacing="10">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label x:Name="RecommendedTitle"
                               Text="Recommended Veterinarian"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="{StaticResource TextColor}"/>
                        <Label Grid.Column="1" Text="See all"
                               TextColor="{StaticResource TitleColor}" />
                    </Grid>

                    <CollectionView x:Name="RecommendedList">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="15"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeShape="RoundRectangle 15"
                                        StrokeThickness="1"
                                        Stroke="{StaticResource EntryColor}"
                                        Padding="15">
                                    <Grid ColumnDefinitions="Auto, *"
                                          RowDefinitions="Auto, Auto, Auto"
                                          ColumnSpacing="15">

                                        <Image Grid.RowSpan="3"
                                               Source="{Binding ImageUrl}"
                                               WidthRequest="60" HeightRequest="60"
                                               Aspect="AspectFill">
                                            <Image.Clip>
                                                <RoundRectangleGeometry CornerRadius="10" Rect="0,0,60,60"/>
                                            </Image.Clip>
                                        </Image>

                                        <VerticalStackLayout Grid.Column="1">
                                            <Label Text="{Binding Name}"
                                                   FontAttributes="Bold" FontSize="16"
                                                   TextColor="{StaticResource TextColor}" />
                                            <Label Text="{Binding Specialization}"
                                                   FontSize="12"
                                                   TextColor="{StaticResource TitleColor}" />
                                            <HorizontalStackLayout Spacing="5">
                                                <Label Text="⭐⭐⭐⭐⭐" FontSize="10"/>
                                                <Label Text="{Binding Rating}"
                                                       FontSize="11" FontAttributes="Bold"
                                                       TextColor="{StaticResource TextColor}"/>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>

                                        <HorizontalStackLayout Grid.Row="1" Grid.Column="1"
                                                               Spacing="15" Margin="0,5">
                                            <Border StrokeShape="RoundRectangle 5"
                                                    BackgroundColor="#E8F5E9"
                                                    Padding="6,2">
                                                <Label Text="{Binding Status}"
                                                       FontSize="10" FontAttributes="Bold"
                                                       TextColor="#4CAF50"/>
                                            </Border>
                                            <Label Text="{Binding Experience}"
                                                   FontSize="11"
                                                   TextColor="{StaticResource TitleColor}" />
                                            <Label Text="{Binding Distance}"
                                                   FontSize="11"
                                                   TextColor="{StaticResource TitleColor}" />
                                        </HorizontalStackLayout>

                                        <Label Grid.Row="2" Grid.Column="1"
                                               Text="{Binding Schedule}"
                                               FontSize="11"
                                               TextColor="{StaticResource TitleColor}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>