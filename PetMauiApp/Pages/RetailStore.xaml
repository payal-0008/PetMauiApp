<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PetMauiApp.Pages.RetailStore"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource BtnTextColor}"
             Title="RetailStore">
    <Grid RowDefinitions="Auto, *, Auto">

        <Grid Grid.Row="0" BackgroundColor="{StaticResource PassColor}" HeightRequest="70" Padding="0,40,0,0">
            <Label Grid.Column="0" Text="Find Retail Stores" TextColor="{StaticResource BtnTextColor}"  
                HeightRequest="70" 
                FontAttributes="Bold" 
                FontSize="18" 
                HorizontalOptions="Center" 
                VerticalOptions="Center"/>
        </Grid>
        <Grid Grid.Row="1">
            <Image Source="remap.png" Aspect="AspectFill"/>
            <VerticalStackLayout VerticalOptions="End" Margin="0,0,0,20">
                <Grid >
                    <Frame Margin="20,80,20,30" CornerRadius="25" HasShadow="True" Padding="20,20,20,40" BackgroundColor="{StaticResource BtnTextColor}" Opacity="0.85">
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Keels Pet Foods" FontAttributes="Bold" FontSize="18"  TextColor="{StaticResource TextColor}"/>
                            </Grid>

                            <Label Text="5.0⭐ ⭐ ⭐ ⭐ ☆" FontSize="13" TextColor="{StaticResource TextColor}" />
                            <Label Text="📍 700m away from you" FontSize="13" TextColor="{StaticResource TitleColor}" />


                            <Button  Text="Call Now" BackgroundColor="{StaticResource PassColor}" TextColor="{StaticResource BtnTextColor}" 
                                     CornerRadius="10" Padding="15,0" HeightRequest="40" HorizontalOptions="End"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Border HeightRequest="80" WidthRequest="80" StrokeShape="RoundRectangle 40"  
                            StrokeThickness="5" Stroke="{StaticResource BtnTextColor}" HorizontalOptions="Center" VerticalOptions="Start">
                        <Image Source="right.png" Aspect="AspectFill"  BackgroundColor="{StaticResource PassColor}" Scale="0.5"/>
                    </Border>
                </Grid>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>